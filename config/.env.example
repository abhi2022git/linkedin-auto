# ===========================================
# LinkedIn Auto-Poster Configuration
# ===========================================

# --- Groq LLM ---
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- LinkedIn OAuth 2.0 ---
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:8080/callback

# --- Posting Configuration ---
POST_SCHEDULE_HOUR=9
POST_SCHEDULE_MINUTE=0
POST_AS_ORGANIZATION=false
ORGANIZATION_ID=your_org_id_here

# --- Image Generation ---
ENABLE_IMAGE_GENERATION=true
HUGGINGFACE_API_KEY=your_hf_token_here
IMAGE_STYLE=auto  # Options: auto, comic, illustration, infographic

# --- Model Selection ---
# Options: auto, llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it, deepseek-r1-distill-llama-70b
PREFERRED_MODEL=auto